# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────
# PostgreSQL (Google Cloud SQL)
# ─────────────────────────────────────────
DATABASE_URL=postgresql://boothmarket_user:yourpassword@localhost:5432/boothmarket

# ─────────────────────────────────────────
# JWT Secrets — use 256-bit random strings
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────
JWT_SECRET=replace_with_256bit_random_string
JWT_REFRESH_SECRET=replace_with_different_256bit_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# Google Cloud Storage
# ─────────────────────────────────────────
GCS_BUCKET_NAME=boothmarket-assets
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account.json

# ─────────────────────────────────────────
# SendGrid Email
# ─────────────────────────────────────────
SENDGRID_API_KEY=SG.replace_with_your_sendgrid_key
FROM_EMAIL=noreply@boothmarket.com
FROM_NAME=BoothMarket

# ─────────────────────────────────────────
# App URLs
# ─────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ADMIN_EMAIL=admin@boothmarket.com

# ─────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
